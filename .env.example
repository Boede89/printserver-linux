# Print-Bridge (lokal — cloudflared auf demselben Host leitet weiter)
PRINT_API_TOKEN=bitte-openssl-rand-hex-32-eintragen
PRINT_DEFAULT_PRINTER=
PRINT_BRIDGE_PORT=8766
# 127.0.0.1 wenn cloudflared auf demselben Host (empfohlen)
PRINT_BRIDGE_BIND=127.0.0.1
# Komma-getrennt, leer = alle Druckernamen erlaubt
PRINT_ALLOWED_PRINTER_PREFIXES=

# Öffentliche URL (nur Doku / später Manager)
PRINT_PUBLIC_URL=https://print.ihre-domain.de

# CUPS im Docker-Container
CUPS_ADMIN_PASSWORD=changeme
